# 🚫 Docker Ignore File
# Archivos y directorios que NO deben incluirse en la imagen Docker

# ========================================
# 📁 Node Modules
# ========================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
yarn.lock

# ========================================
# 📝 Logs y Datos Temporales
# ========================================
logs/
*.log
*.log.*
*.pid
*.seed
*.pid.lock
temp/
tmp/

# ========================================
# 🔐 Archivos Sensibles
# ========================================
.env
.env.local
.env.*.local
data/
redis_data/
*.secrets
init.json

# ========================================
# 🛠️ Desarrollo
# ========================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ========================================
# 📦 Git
# ========================================
.git/
.gitignore
.gitattributes

# ========================================
# 🧪 Testing
# ========================================
coverage/
.nyc_output/
test/
tests/
*.test.js
*.spec.js

# ========================================
# 📚 Documentation (opcional)
# ========================================
README.md
CHANGELOG.md
LICENSE
docs/
*.md
!DEPLOY_COOLIFY.md

# ========================================
# 🐳 Docker
# ========================================
docker-compose.yml
docker-compose.*.yml
Dockerfile
.dockerignore

# ========================================
# 🚀 CI/CD
# ========================================
.github/
.gitlab-ci.yml
.travis.yml
.circleci/

# ========================================
# 📋 Scripts de Desarrollo
# ========================================
scripts/test-*.js
scripts/dev-*.js
scripts/debug-*.js

# ========================================
# 🎨 Frontend (se construye por separado)
# ========================================
web/admin-spa/node_modules/
web/admin-spa/dist/
web/admin-spa/.cache/
web/admin-spa/coverage/

# ========================================
# ☁️ Coolify
# ========================================
.coolify
